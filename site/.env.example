# SaaSKit platform backend URL
SAASKIT_URL=http://localhost:8083

# App Key from SaaSKit admin panel → Applications
APP_KEY=app_xxxxxxxxxxxxxxxx

# API Client credentials from SaaSKit admin panel → API Clients
API_KEY=client_xxxxxxxxxxxxxxxx
API_SECRET=your_api_secret_here

# Site server port (Express backend)
PORT=3001
