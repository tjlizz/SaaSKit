HOST_PORT=8080
POSTGRES_DB=saaskit
POSTGRES_USER=saaskit
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://saaskit:change-me@postgres:5432/saaskit?sslmode=disable
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-with-at-least-32-random-characters
PAYMENT_CONFIG_KEY=replace-with-a-different-long-random-secret
PAYMENT_MOCK=true
PUBLIC_URL=http://localhost:8080
FRONTEND_ORIGINS=http://localhost:5666
AUTO_MIGRATE=true
ALLOW_USER_REGISTRATION=true
